APP_DIR="$HOME/.aims-notifs"
BIN_DIR="$HOME/.local/bin"
COMPLETIONS_DIR="$HOME/.local/share/bash-completion/completions"
SYSTEMD_DIR="$HOME/.config/systemd/user"

case "$1" in

setup)
    rm -rf /tmp/test-venv
    python3 -m venv /tmp/test-venv >/dev/null 2>&1

    if [ ! -x /tmp/test-venv/bin/pip ]; then
        echo "Python venv support (ensurepip) is missing."

        if command -v apt >/dev/null 2>&1; then
            echo "Installing python3-venv..."
            sudo apt install -y python3-venv

            rm -rf /tmp/test-venv
            python3 -m venv /tmp/test-venv >/dev/null 2>&1

            if [ ! -x /tmp/test-venv/bin/pip ]; then
                echo "Failed to install working venv support."
                echo "Please install your system's Python venv package (using 'sudo apt install python3-venv'), and rerun."
                exit 1
            fi
        else
            echo "Please install your system's Python venv package (using 'sudo apt install python3-venv'), and rerun."
            exit 1
        fi
    fi

    rm -rf /tmp/test-venv

    python3 -m venv "$APP_DIR/venv"

    "$APP_DIR/venv/bin/pip" install \
        --upgrade pip

    "$APP_DIR/venv/bin/pip" install \
        -r "$APP_DIR/requirements.txt"

    "$APP_DIR/venv/bin/python" \
        -m playwright install chromium

    "$APP_DIR/venv/bin/python" \
        "$APP_DIR/setup.py"

    mkdir -p "$SYSTEMD_DIR"

    cat > "$SYSTEMD_DIR/aims-notifs.service" <<EOF
[Unit]
Description=IITH AIMS Grade Notification System

[Service]
Type=oneshot
WorkingDirectory=$APP_DIR
ExecStart=$APP_DIR/venv/bin/python $APP_DIR/main.py
EOF

    cat > "$SYSTEMD_DIR/aims-notifs.timer" <<EOF
[Unit]
Description=IITH AIMS Grade Notification System Timer

[Timer]
OnBootSec=1min
OnUnitActiveSec=15min

[Install]
WantedBy=timers.target
EOF

    systemctl --user daemon-reload

    echo
    echo "Setup complete."
    echo "Starting IITH AIMS Grade Notification System..."
    aims-notifs start
    ;;

start)

    systemctl --user enable aims-notifs.timer
    systemctl --user start aims-notifs.timer

    echo "IITH AIMS Grade Notification System started."
    ;;

stop)

    systemctl --user stop aims-notifs.timer

    echo "IITH AIMS Grade Notification System stopped."
    ;;

status)

    echo "Press 'q' to exit the status view."
    echo
    systemctl --user status aims-notifs.timer
    ;;

run-now)

    systemctl --user start aims-notifs.service
    ;;

logs)

    echo "Press 'Ctrl+C' to exit the logs view."
    echo
    echo "Logs are stored in the systemd journal."
    echo
    echo "View all logs:"
    echo "  journalctl --user -u aims-notifs.service"
    echo

    journalctl --user -u aims-notifs.service -f
    ;;

uninstall)

    systemctl --user stop aims-notifs.timer 2>/dev/null || true
    systemctl --user disable aims-notifs.timer 2>/dev/null || true

    rm -f "$SYSTEMD_DIR/aims-notifs.service"
    rm -f "$SYSTEMD_DIR/aims-notifs.timer"

    systemctl --user daemon-reload

    rm -f "$COMPLETIONS_DIR/aims-notifs"
    rm -f "$BIN_DIR/aims-notifs"
    rm -rf "$APP_DIR"

    echo "IITH AIMS Grade Notification System uninstalled."
    ;;

*)

    echo "Usage:"
    echo "  aims-notifs setup"
    echo "  aims-notifs start"
    echo "  aims-notifs stop"
    echo "  aims-notifs status"
    echo "  aims-notifs run-now"
    echo "  aims-notifs logs"
    echo "  aims-notifs uninstall"

    exit 1
    ;;
esac
